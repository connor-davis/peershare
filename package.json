{
  "name": "peer-share",
  "version": "0.0.2",
  "description": "Share your files with peer to peer technologies.",
  "main": "app/build/main.js",
  "scripts": {
    "start": "vite",
    "dev": "vite --host",
    "build": "vite build && npm run copyFiles",
    "serve": "vite preview",
    "prod": "npm run build && git add . && git commit -m \"Production build\" && git push",
    "electron": "electron ./electron/main.js",
    "electron:test": "wait-on http://localhost:3000/ && echo \"Ready\"",
    "test": "concurrently \"npm run electron\" \"npm run dev\" --kill-others --success first",
    "copyFiles": "npm run copyBuild && npm run copyBuild",
    "copyBuild": "copy-files-from-to",
    "electron-build": "electron-packager ./build --out=dist",
    "pack": "electron-builder --dir",
    "distWin": "electron-builder --win --x64",
    "distLinux": "electron-builder --linux --x64",
    "distMac": "electron-builder --osx --x64",
    "gh-publish-win": "npm run build && electron-builder --win --x64 -p always"
  },
  "repository": "git@github.com:connor-davis/peershare.git",
  "author": "Connor Davis <cnnrproton@gmail.com>",
  "copyFiles": [
    {
      "from": "dist/**/*",
      "to": "app/build/"
    },
    {
      "from": "electron/**/*",
      "to": "app/build/"
    }
  ],
  "build": {
    "appId": "software.lone-wolf.peershare",
    "compression": "maximum",
    "productName": "PeerShare",
    "target": "NSIS",
    "win": {
      "icon": "./public/icon.png"
    },
    "files": [
      "app/**/**/*"
    ],
    "asar": true,
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false
    },
    "directories": {
      "buildResources": "public"
    }
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.1",
    "autoprefixer": "^10.4.2",
    "concurrently": "^7.2.1",
    "cross-env": "^7.0.3",
    "electron": "^19.0.1",
    "electron-builder": "^23.0.3",
    "electron-devtools-installer": "^3.2.0",
    "electron-packager": "^15.5.1",
    "postcss": "^8.4.5",
    "tailwindcss": "^3.0.18",
    "vite": "^2.9.9",
    "vite-plugin-solid": "^2.2.6",
    "wait-on": "^6.0.1"
  },
  "dependencies": {
    "@hyperswarm/dht": "^5.0.25",
    "@rturnq/solid-router": "^0.3.0",
    "@telios/nebula": "^2.5.8",
    "copy-files-from-to": "^3.2.2",
    "dotenv": "^16.0.1",
    "electron-updater": "^5.0.1",
    "file-type": "^17.1.1",
    "hypercore-crypto": "^3.2.1",
    "hyperdrive": "^10.21.0",
    "hyperswarm": "^3.0.4",
    "mime-types": "^2.1.35",
    "portfinder": "^1.0.28",
    "progress-stream": "^2.0.0",
    "rxjs": "^7.5.5",
    "socket.io": "^4.5.1",
    "solid-js": "^1.4.2",
    "solid-transition-group": "^0.0.8",
    "util": "^0.12.4"
  }
}
