{
  "name": "peer-share",
  "version": "0.0.1",
  "description": "Share your files and ports with peer to peer technologies.",
  "main": "electron/main.js",
  "scripts": {
    "start": "vite",
    "dev": "vite --host",
    "build": "vite build",
    "serve": "vite preview",
    "prod": "pnpm build && git add . && git commit -m \"Production build\" && git push",
    "electron": "electron .",
    "electron:test": "wait-on http://localhost:3000/ && echo \"Ready\"",
    "test": "concurrently \"pnpm electron\" \"pnpm dev\" --kill-others --success first"
  },
  "license": "MIT",
