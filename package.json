    "@hyperswarm/dht": "^5.0.25",
    "@rturnq/solid-router": "^0.3.0",
    "@telios/nebula": "^2.5.8",
    "axios": "^0.27.2",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.20.0",
    "chalk": "^5.0.1",
    "compression": "^1.7.4",
    "concurrently": "^7.2.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
